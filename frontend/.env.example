NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Optional. Only use this in server-only code when you intentionally need to
# bypass Row Level Security for admin automation. Do not expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional but recommended for auth emails in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
